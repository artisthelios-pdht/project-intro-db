<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Hệ Thống Quản Lý Thư Viện - SOT</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  {{{_sections.css}}}
  <style>
    /* Đảm bảo hình ảnh trong card không bị méo */
    .card-img-top {
      height: 180px;
      object-fit: cover;
    }

    /* Tùy chỉnh thanh cuộn cho đẹp */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-thumb {
      background: #ccc;
      border-radius: 10px;
    }
  </style>
</head>

<body style="height: 100vh; display: flex; flex-direction: column; overflow: hidden;">

  <nav class="navbar navbar-expand-lg bg-dark navbar-dark shadow-sm" style="flex-shrink: 0;">
    <div class="container-fluid">
      <a class="navbar-brand fw-bold" href="/homelb"><i class="fa-solid fa-book-open-reader"></i> SOT LIBRARY</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <li class="nav-item"><a class="nav-link active" href="/homelb">Trang chủ</a></li>
          <li class="nav-item"><a class="nav-link" href="#">Báo cáo</a></li>
        </ul>
        <form class="d-flex" role="search" action="/search" method="GET">
          <input class="form-control me-2" type="search" name="q" placeholder="Tìm tên sách...">
          <button class="btn btn-outline-light" type="submit"><i class="bi bi-search"></i></button>
        </form>
      </div>
    </div>
  </nav>

  <div class="container-fluid flex-grow-1" style="overflow: hidden;">
    <div class="row h-100">

      <div class="col-md-3 py-4 border-end bg-white" style="height: 100%; overflow-y: auto;">

        <div class="card mb-3 shadow-sm">
          <h5 class="card-header bg-primary text-white small fw-bold">DANH MỤC</h5>
          <div class="list-group list-group-flush">
            <a href="/homelb" class="list-group-item list-group-item-action">Tất cả sách</a>
            <a href="#" class="list-group-item list-group-item-action">Sách đang mượn</a>
          </div>
        </div>

        <div class="card shadow-sm mb-3">
          <h5 class="card-header bg-info text-white small fw-bold text-center">
            <i class="bi bi-pie-chart"></i> KHO SÁCH NXB
          </h5>
          <ul class="list-group list-group-flush">
            {{#if statsNXB}}
            {{#each statsNXB}}
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span class="small fw-semibold" style="line-height: 1.2;">
                {{this.book_PublisherName}}
              </span>
              <span class="badge bg-secondary rounded-pill">{{this.total}}</span>
            </li>
            {{/each}}
            {{else}}
            <li class="list-group-item small text-muted text-center">Đang tải dữ liệu...</li>
            {{/if}}
          </ul>
        </div>

        {{#if topBook}}
        <div class="card shadow-sm border-warning border-2">
          <div class="card-body p-3">
            <h6 class="card-title text-warning fw-bold small">
              <i class="bi bi-fire"></i> SÁCH MƯỢN NHIỀU
            </h6>
            <p class="card-text mb-1 fw-bold text-dark small">{{topBook.book_Title}}</p>
            <div class="progress" style="height: 5px;">
              <div class="progress-bar bg-warning" style="width: 100%"></div>
            </div>
            <p class="mt-2 mb-0" style="font-size: 0.7rem;">Lượt mượn: <strong>{{topBook.total_loans}}</strong></p>
          </div>
        </div>
        {{/if}}
      </div>

      <div class="col-md-9 py-4 bg-light" style="height: 100%; overflow-y: auto;">
        <div class="container-fluid">
          {{{body}}}
        </div>
      </div>

    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  {{{_sections.js}}}
</body>

</html>